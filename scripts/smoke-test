#!/usr/bin/env bash
set -euo pipefail

php craft plugin/list

php craft exec '
use Craft;
use lindemannrock\redirectmanager\RedirectManager;
use lindemannrock\redirectmanager\models\Settings;
use lindemannrock\logginglibrary\LoggingLibrary;

$plugins = Craft::$app->getPlugins();
$plugin = $plugins->getPlugin("redirect-manager");

if (!$plugin instanceof RedirectManager) {
    throw new RuntimeException("Redirect Manager plugin class was not loaded.");
}

foreach (["redirect-manager", "logging-library"] as $handle) {
    if (!$plugins->isPluginInstalled($handle) || !$plugins->isPluginEnabled($handle)) {
        throw new RuntimeException("Required Craft plugin is not installed and enabled: {$handle}");
    }
}

if (!$plugins->getPlugin("logging-library") instanceof LoggingLibrary) {
    throw new RuntimeException("Logging Library dependency was not loaded.");
}

$baseModule = Craft::$app->getModule("lindemannrock-base");
if (!$baseModule instanceof \yii\base\Module) {
    throw new RuntimeException("Base module was not registered.");
}

$settings = $plugin->getSettings();
if (!$settings instanceof Settings) {
    throw new RuntimeException("Redirect Manager settings model was not loaded.");
}

if ($settings->redirectSrcMatch !== "pathonly" || $settings->enableAnalytics !== true || $settings->backupEnabled !== true) {
    throw new RuntimeException("Redirect Manager fresh-install settings defaults are not intact.");
}

foreach (["redirects", "analytics", "matching", "deviceDetection", "backup"] as $component) {
    if (!$plugin->has($component)) {
        throw new RuntimeException("Missing Redirect Manager service component: {$component}");
    }
    $plugin->get($component);
}

echo "Redirect Manager smoke test passed.\n";
'

{
    "name": "lindemannrock/craft-redirect-manager",
    "description": "Intelligent redirect management and 404 handling for Craft CMS",
    "type": "craft-plugin",
    "version": "5.31.0",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "redirect",
        "301",
        "404",
        "seo"
    ],
    "license": "proprietary",
    "authors": [
        {
            "name": "Bilal Hary Lindemann",
            "email": "bh@lindemannrock.com",
            "homepage": "https://lindemannrock.com",
            "role": "Developer"
        }
    ],
    "support": {
        "email": "support@lindemannrock.com",
        "issues": "https://github.com/LindemannRock/craft-redirect-manager/issues",
        "source": "https://github.com/LindemannRock/craft-redirect-manager",
        "docs": "https://github.com/LindemannRock/craft-redirect-manager/blob/main/README.md"
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0.0",
        "lindemannrock/craft-plugin-base": "^5.0",
        "lindemannrock/craft-logging-library": "^5.0"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main",
        "phpunit/phpunit": "^11.0",
        "yiisoft/yii2-redis": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "lindemannrock\\redirectmanager\\": "src/",
            "lindemannrock\\redirectmanager\\tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "phpstan --ansi --memory-limit=1G",
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --fix --ansi",
        "test": "phpunit --colors=always",
        "install-hooks": "git config core.hooksPath .githooks 2>/dev/null || true",
        "post-install-cmd": "@install-hooks",
        "post-update-cmd": "@install-hooks"
    },
    "config": {
        "allow-plugins": {
            "craftcms/plugin-installer": true,
            "yiisoft/yii2-composer": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "name": "Redirect Manager",
        "handle": "redirect-manager",
        "developer": "LindemannRock",
        "developerUrl": "https://lindemannrock.com",
        "documentationUrl": "https://github.com/LindemannRock/craft-redirect-manager/blob/main/README.md",
        "changelogUrl": "https://github.com/LindemannRock/craft-redirect-manager/blob/main/CHANGELOG.md",
        "class": "lindemannrock\\redirectmanager\\RedirectManager"
    }
}

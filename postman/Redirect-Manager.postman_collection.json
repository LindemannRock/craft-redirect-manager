          }
        },
        {
          "name": "Rate limit probe - repeat with Runner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 429', function () { pm.expect([200, 429]).to.include(pm.response.code); });",
                  "if (pm.response.code === 429) {",
                  "    pm.test('Retry-After header is present', function () { pm.response.to.have.header('Retry-After'); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/actions/redirect-manager/api/get-redirects",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "actions",
                "redirect-manager",
                "api",
                "get-redirects"
              ]
            }
          }
        }
      ]
    }
  ]
}

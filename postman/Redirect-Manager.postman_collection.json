              ]
            }
          }
        },
        {
          "name": "Missing Accept header - 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400', function () { pm.response.to.have.status(400); });"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/actions/redirect-manager/api/get-redirects",
              "host": [
                "{{base_url}}"

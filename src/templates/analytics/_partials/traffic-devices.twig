{# Traffic & Devices Tab - Bot stats, Device Types, Browsers, OS (all AJAX-loaded) #}

<h2 style="margin: 0 0 20px;">{{ "Traffic Analysis"|t('redirect-manager') }}</h2>

<div class="lr-analytics-charts two-columns">
    <div class="lr-chart-container">
        <h3>{{ "Bot vs Human Traffic"|t('redirect-manager') }}</h3>
        <canvas id="bot-chart"></canvas>
        <div id="bot-percentage-text" style="text-align: center; margin-top: 10px; color: #666;"></div>
    </div>

    <div class="lr-chart-container">
        <h3>{{ "Top Bots"|t('redirect-manager') }}</h3>
        <div class="lr-table-scroll">
            <table class="data fullwidth" id="top-bots-table">
                <thead>
                    <tr>
                        <th>{{ "Bot Name"|t('redirect-manager') }}</th>
                        <th>{{ "404s"|t('redirect-manager') }}</th>
                    </tr>
                </thead>
                <tbody id="top-bots-body">
                    <tr>
                        <td colspan="2" class="thin light" style="text-align: center;">{{ "Loading…"|t('redirect-manager') }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<h2 style="margin: 30px 0 20px;">{{ "Device Analytics"|t('redirect-manager') }}</h2>

<div class="lr-analytics-charts two-columns">
    <div class="lr-chart-container">
        <h3>{{ "Device Types"|t('redirect-manager') }}</h3>
        <canvas id="device-chart"></canvas>
    </div>

    <div class="lr-chart-container">
        <h3>{{ "Browser Usage"|t('redirect-manager') }}</h3>
        <canvas id="browser-chart"></canvas>
    </div>
</div>

<div class="lr-analytics-charts" style="margin-top: 30px;">
    <div class="lr-chart-container">
        <h3>{{ "Operating Systems"|t('redirect-manager') }}</h3>
        <canvas id="os-chart"></canvas>
    </div>
</div>

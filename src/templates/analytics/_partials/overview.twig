{# Overview Tab - Stats, Trend, Most Common, Recent Unhandled #}

<div class="lr-unified-cards">
    {% include 'lindemannrock-base/_components/unified-card' with {
        value: totalCount ?? 0,
        description: 'Total 404s'|t('redirect-manager'),
        align: 'center',
    } only %}

    {% include 'lindemannrock-base/_components/unified-card' with {
        value: handledCount ?? 0,
        description: 'Handled'|t('redirect-manager'),
        align: 'center',
    } only %}

    {% include 'lindemannrock-base/_components/unified-card' with {
        value: unhandledCount ?? 0,
        description: 'Unhandled'|t('redirect-manager'),
        align: 'center',
    } only %}

    {% include 'lindemannrock-base/_components/unified-card' with {
        value: (totalCount > 0 ? ((handledCount / totalCount * 100)|round) : 0) ~ '%',
        description: 'Success Rate'|t('redirect-manager'),
        align: 'center',
    } only %}
</div>

<h2 class="lr-section-heading">{{ "404 Trend"|t('redirect-manager') }}</h2>

<div class="lr-analytics-charts">
    <div class="lr-chart-container full-width">
        <canvas id="404-trend-chart"></canvas>
    </div>
</div>

<h2 class="lr-section-heading">{{ "Most Common 404s (Top 15)"|t('redirect-manager') }}</h2>

<div class="lr-analytics-charts">
    <div class="lr-chart-container full-width">
        <div class="lr-table-scroll">
            <table class="data fullwidth" id="most-common-table">
                <thead>
                    <tr>
                        <th>{{ 'URL'|t('redirect-manager') }}</th>
                        <th>{{ 'Site'|t('redirect-manager') }}</th>
                        <th>{{ 'Hits'|t('redirect-manager') }}</th>
                        <th>{{ 'Handled'|t('redirect-manager') }}</th>
                        <th>{{ 'Type'|t('redirect-manager') }}</th>
                        <th>{{ 'Agent'|t('redirect-manager') }}</th>
                        <th>{{ 'Last Hit'|t('redirect-manager') }}</th>
                    </tr>
                </thead>
                <tbody>
	                    {% for stat in mostCommon %}
	                        <tr>
	                            <td>
	                                {% set isSafeUrl = stat.url starts with '/' or stat.url starts with 'http://' or stat.url starts with 'https://' %}
	                                {% if isSafeUrl %}
	                                    <a class="label-link" href="{{ stat.url }}" target="_blank" rel="noopener noreferrer">
	                                        <span><code>{{ stat.url|slice(0, 80) }}</code></span>
	                                    </a>
	                                {% else %}
	                                    <span><code>{{ stat.url|slice(0, 80) }}</code></span>
	                                {% endif %}
	                            </td>
                            <td>
                                {% if stat.siteId %}
                                    {% set site = craft.app.sites.getSiteById(stat.siteId) %}
                                    {{ site ? site.name : '—' }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td><strong>{{ stat.count|number }}</strong></td>
                            <td>
                                {% if stat.handled %}
                                    {% include 'lindemannrock-base/_components/badge' with {
                                        label: 'Yes'|t('redirect-manager'),
                                        value: 'yes',
                                        colorSet: 'yesNo',
                                    } only %}
                                {% else %}
                                    {% include 'lindemannrock-base/_components/badge' with {
                                        label: 'No'|t('redirect-manager'),
                                        value: 'no',
                                        colorSet: 'yesNo',
                                    } only %}
                                {% endif %}
                            </td>
                            <td>
                                {% set rType = stat.requestType|default('normal') %}
                                {% set typeLabel = rType == 'probe' ? 'Probe' : (rType == 'system' ? 'System' : (rType == 'bot' ? 'Bot' : 'Normal')) %}
                                {% include 'lindemannrock-base/_components/badge' with {
                                    label: typeLabel|t('redirect-manager'),
                                    value: rType,
                                    colorSet: 'requestType',
                                } only %}
                            </td>
                            <td>
                                {% set agentTitleParts = [stat.botCategory ?? null, stat.botProducerName ?? null]|filter %}
                                {% set agentTitle = agentTitleParts|length ? agentTitleParts|join(' · ') : null %}
                                {% if stat.botName %}
                                    <span{% if agentTitle %} title="{{ agentTitle }}"{% endif %}>{{ stat.botName }}</span>
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td>{{ stat.lastHit|lrDatetime }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="thin light">{{ "No 404s recorded yet"|t('redirect-manager') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<h2 class="lr-section-heading">{{ "Recent Unhandled 404s"|t('redirect-manager') }}</h2>

<div class="lr-analytics-charts">
    <div class="lr-chart-container full-width">
        <div class="lr-table-scroll">
            <table class="data fullwidth" id="recent-unhandled-table">
                <thead>
                    <tr>
                        <th>{{ 'URL'|t('redirect-manager') }}</th>
                        <th>{{ 'Site'|t('redirect-manager') }}</th>
                        <th>{{ 'Hits'|t('redirect-manager') }}</th>
                        <th>{{ 'Type'|t('redirect-manager') }}</th>
                        <th>{{ 'Agent'|t('redirect-manager') }}</th>
                        <th>{{ 'Referrer'|t('redirect-manager') }}</th>
                        <th>{{ 'Last Hit'|t('redirect-manager') }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="recent-unhandled-body">
                    <tr>
                        <td colspan="8" class="thin light">{{ "Loading..."|t('redirect-manager') }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

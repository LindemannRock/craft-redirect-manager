{# Geographic Tab - Countries and Cities (all AJAX-loaded) #}

{% set settings = craft.app.plugins.getPlugin('redirect-manager').settings %}

{% if settings.enableGeoDetection %}
    <h2 style="margin: 0 0 20px;">{{ "Geographic Analytics"|t('redirect-manager') }}</h2>

    <div class="lr-analytics-charts two-columns">
        <div class="lr-chart-container">
            <h3>{{ "Top Countries"|t('redirect-manager') }}</h3>
            <div class="lr-table-scroll">
                <table class="data fullwidth" id="countries-table">
                    <thead>
                        <tr>
                            <th>{{ "Country"|t('redirect-manager') }}</th>
                            <th>{{ "404s"|t('redirect-manager') }}</th>
                            <th>{{ "Percentage"|t('redirect-manager') }}</th>
                        </tr>
                    </thead>
                    <tbody id="countries-body">
                        <tr>
                            <td colspan="3" class="thin light" style="text-align: center;">{{ "Loading…"|t('redirect-manager') }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="lr-chart-container">
            <h3>{{ "Top Cities"|t('redirect-manager') }}</h3>
            <div class="lr-table-scroll">
                <table class="data fullwidth" id="cities-table">
                    <thead>
                        <tr>
                            <th>{{ "City"|t('redirect-manager') }}</th>
                            <th>{{ "Country"|t('redirect-manager') }}</th>
                            <th>{{ "404s"|t('redirect-manager') }}</th>
                            <th>{{ "Percentage"|t('redirect-manager') }}</th>
                        </tr>
                    </thead>
                    <tbody id="cities-body">
                        <tr>
                            <td colspan="4" class="thin light" style="text-align: center;">{{ "Loading…"|t('redirect-manager') }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% else %}
    <div class="lr-analytics-empty">
        <p>{{ "Geographic detection is disabled."|t('redirect-manager') }}</p>
        <p><a href="{{ url('redirect-manager/settings/analytics') }}" class="btn">{{ "Enable in Settings"|t('redirect-manager') }}</a></p>
    </div>
{% endif %}

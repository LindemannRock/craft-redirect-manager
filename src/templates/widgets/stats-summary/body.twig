<div class="redirect-manager-widget">
    {% if total > 0 %}
        {% include 'lindemannrock-base/_components/chart-container' with {
            id: chartId,
            type: 'doughnut',
            height: 250,
            center: true,
            class: 'lr-dashboard-widget-chart',
            percentageTooltip: true,
            data: {
                labels: [
                    'Handled'|t('redirect-manager'),
                    'Unhandled'|t('redirect-manager'),
                ],
                datasets: [
                    {
                        data: [totalHandled, totalUnhandled],
                        backgroundColor: ['#10b981', '#ef4444'],
                        borderWidth: 0,
                    },
                ],
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 10,
                            font: {
                                size: 11,
                            },
                        },
                    },
                },
            },
        } only %}

        {% include 'lindemannrock-base/_components/dashboard-widget-footer' with {
            url: cpUrl('redirect-manager/analytics'),
            label: "View all analytics"|t('redirect-manager'),
        } only %}
    {% else %}
        {% include 'lindemannrock-base/_components/dashboard-widget-empty' with {
            title: "No 404s recorded"|t('redirect-manager'),
            message: "404 errors will appear here when they occur."|t('redirect-manager'),
        } only %}
    {% endif %}
</div>

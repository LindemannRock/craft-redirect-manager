{% set pluginName = redirectHelper.fullName %}
{% set rows = [] %}

{% for stat in stats %}
    {% set meta %}
        {% if stat.lastHit %}
            {{ "Last seen"|t('redirect-manager') }}: {{ stat.lastHit|lrDatetime }}
        {% endif %}
    {% endset %}
    {% set rows = rows|merge([{
        primary: stat.url,
        primaryUrl: cpUrl('redirect-manager/analytics') ~ '#url-' ~ stat.url|url_encode,
        primaryTitle: stat.url,
        primaryVariant: 'danger',
        badgeVariant: 'danger',
        metaHtml: meta,
        value: stat.count|number,
    }]) %}
{% endfor %}

{% include 'lindemannrock-base/_components/dashboard-widget-list' with {
    primaryHeader: "URL"|t('redirect-manager'),
    valueHeader: "Hits"|t('redirect-manager'),
    rows: rows,
    empty: {
        title: "No unhandled 404s"|t('redirect-manager'),
        message: "Great! All 404s are being handled by {pluginName}."|t('redirect-manager', {pluginName: pluginName|lower}),
        type: 'success',
    },
    footer: {
        url: cpUrl('redirect-manager/analytics'),
        label: "View all 404s"|t('redirect-manager'),
    },
} only %}

{% extends "redirect-manager/_layouts/settings" %}
{% set title = "Interface Settings"|t('redirect-manager') %}
{% set fullPageForm = true %}
{% set selectedSettingsItem = 'interface' %}

{% set plugin = craft.app.plugins.getPlugin('redirect-manager') %}
{% set crumbs = [
    {
        label: redirectHelper.fullName|t('redirect-manager'),
        url: url('redirect-manager'),
    },
    {
        label: 'Settings'|t('redirect-manager'),
        url: url('redirect-manager/settings'),
    },
    {
        label: 'Interface'|t('redirect-manager'),
        url: url('redirect-manager/settings/interface'),
    },
] %}

{% import "_includes/forms" as forms %}

{% block content %}

	{{ actionInput('redirect-manager/settings/save') }}
	{{ redirectInput('redirect-manager/settings/interface') }}
	{{ hiddenInput('section', 'interface') }}

		<h2 class="first">{{ "Interface Settings"|t('redirect-manager') }}</h2>

		{% include 'lindemannrock-base/_partials/field-items-per-page' with {
            settings: settings,
            pluginHandle: 'redirect-manager',
        } only %}

		{{ forms.selectField({
            label: 'Dashboard Refresh Interval'|t('redirect-manager'),
            instructions: 'How often to refresh dashboard data. Set to Off to disable auto-refresh.'|t('redirect-manager'),
            id: 'refreshIntervalSecs',
            name: 'settings[refreshIntervalSecs]',
            value: settings.refreshIntervalSecs,
            required: true,
            options: {
                0: 'Off'|t('redirect-manager'),
                15: '15 seconds'|t('redirect-manager'),
                30: '30 seconds'|t('redirect-manager'),
                60: '60 seconds (1 minute)'|t('redirect-manager'),
                120: '120 seconds (2 minutes)'|t('redirect-manager'),
            },
            errors: settings.getErrors('refreshIntervalSecs'),
            disabled: settings.isOverriddenByConfig('refreshIntervalSecs'),
            warning: settings.isOverriddenByConfig('refreshIntervalSecs') ?
                "This is being overridden by the <code>refreshIntervalSecs</code> setting in <code>config/redirect-manager.php</code>."|t('redirect-manager')|raw : null,
        }) }}

		<hr>

		{% include 'lindemannrock-base/_partials/cascade-base-overrides' with {
            settings: settings,
            pluginHandle: 'redirect-manager',
            sections: {
                dateFormat: {},
                dateRange: {},
                exports: {},
            },
        } only %}

	{% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}

{% extends "redirect-manager/_layouts/settings" %}
{% set title = "Cache Settings"|t('redirect-manager') %}
{% set fullPageForm = true %}
{% set selectedSettingsItem = 'cache' %}

{% set plugin = craft.app.plugins.getPlugin('redirect-manager') %}
{% set crumbs = [
    {
        label: redirectHelper.fullName|t('redirect-manager'),
        url: url('redirect-manager'),
    },
    {
        label: 'Settings'|t('redirect-manager'),
        url: url('redirect-manager/settings'),
    },
    {
        label: 'Cache'|t('redirect-manager'),
        url: url('redirect-manager/settings/cache'),
    },
] %}

{% import "_includes/forms" as forms %}

{% block content %}

	<form method="post" accept-charset="UTF-8">
		{{ actionInput('redirect-manager/settings/save') }}
		{{ csrfInput() }}
		{{ redirectInput('redirect-manager/settings/cache') }}
		{{ hiddenInput('section', 'cache') }}

		<h2 style="margin-top: 0px;">{{ "Cache Storage Settings"|t('redirect-manager') }}</h2>

		{{ forms.selectField({
			label: 'Cache Storage Method'|t('redirect-manager'),
			instructions: 'How to store cache data. Use Redis/Database for load-balanced or multi-server environments.'|t('redirect-manager'),
			id: 'cacheStorageMethod',
			name: 'settings[cacheStorageMethod]',
			value: settings.cacheStorageMethod ?? 'file',
			options: [
				{ value: 'file', label: 'File System (default, single server)'|t('redirect-manager') },
				{ value: 'redis', label: 'Redis/Database (load-balanced, multi-server, cloud hosting)'|t('redirect-manager') },
			],
			errors: settings.getErrors('cacheStorageMethod'),
			disabled: settings.isOverriddenByConfig('cacheStorageMethod'),
			warning: settings.isOverriddenByConfig('cacheStorageMethod') ?
				"This is being overridden by the <code>cacheStorageMethod</code> setting in <code>config/redirect-manager.php</code>."|t('redirect-manager')|raw : null,
		}) }}

		{% set craftUsesRedis = craft.app.cache is defined and craft.app.cache.className is defined and craft.app.cache.className == 'yii\\redis\\Cache' %}

		<div id="cache-location-file" class="{{ (settings.cacheStorageMethod ?? 'file') == 'redis' ? 'hidden' }}">
			{% include 'lindemannrock-base/_components/info-box' with {
				message: '<strong>' ~ 'Cache Location'|t('redirect-manager') ~ ':</strong> <code>' ~ redirectHelper.cacheBasePath ~ '</code>',
				type: 'info'
			} %}
		</div>

		<div id="cache-location-redis" class="{{ (settings.cacheStorageMethod ?? 'file') == 'file' ? 'hidden' }}">
			{% if craftUsesRedis %}
				{% include 'lindemannrock-base/_components/info-box' with {
					type: 'success',
					message: '<strong>' ~ 'Cache Location'|t('redirect-manager') ~ ':</strong> ' ~ "Using Craft's configured Redis cache from <code>config/app.php</code>"|t('redirect-manager')
				} %}
			{% else %}
				{% include 'lindemannrock-base/_components/info-box' with {
					type: 'warning',
					message: '<strong>' ~ 'Redis Not Configured'|t('redirect-manager') ~ ':</strong> ' ~ "To use Redis caching, install <code>yiisoft/yii2-redis</code> and configure it in <code>config/app.php</code>."|t('redirect-manager') ~ ' <a href="https://craftcms.com/docs/5.x/reference/config/app.html#cache" target="_blank" rel="noopener">' ~ 'Learn more'|t('redirect-manager') ~ '</a>'
				} %}
			{% endif %}
		</div>

		<hr>

		<h2>{{ "Device Detection Caching"|t('redirect-manager') }}</h2>

		{% if settings.enableAnalytics ?? true %}

			{{ forms.lightswitchField({
                label: "Cache Device Detection"|t('redirect-manager'),
                instructions: "Cache device detection results for better performance"|t('redirect-manager'),
                id: 'cacheDeviceDetection',
                name: 'settings[cacheDeviceDetection]',
                on: settings.cacheDeviceDetection ?? true,
                toggle: 'device-cache-settings',
                errors: settings.getErrors('cacheDeviceDetection'),
                disabled: settings.isOverriddenByConfig('cacheDeviceDetection'),
                warning: settings.isOverriddenByConfig('cacheDeviceDetection') ?
                    "This is being overridden by the <code>cacheDeviceDetection</code> setting in <code>config/redirect-manager.php</code>."|t('redirect-manager')|raw : null,
            }) }}

			<div id="device-cache-settings" class="{{ not (settings.cacheDeviceDetection ?? true) ? 'hidden' }}">
				{{ forms.textField({
	                label: "Device Detection Cache Duration"|t('redirect-manager'),
	                instructions: ('Cache duration in seconds. Current:'|t('redirect-manager') ~ ' <strong id="deviceDetectionCacheDuration-human"></strong>')|raw,
	                id: 'deviceDetectionCacheDuration',
	                name: 'settings[deviceDetectionCacheDuration]',
	                value: settings.deviceDetectionCacheDuration ?? 3600,
	                type: 'number',
	                min: 60,
	                max: 604800,
	                tip: 'Min: 60 (1 minute), Max: 604800 (7 days)'|t('redirect-manager'),
                    errors: settings.getErrors('deviceDetectionCacheDuration'),
	                disabled: settings.isOverriddenByConfig('deviceDetectionCacheDuration'),
	                warning: settings.isOverriddenByConfig('deviceDetectionCacheDuration') ?
	                    "This is being overridden by the <code>deviceDetectionCacheDuration</code> setting in <code>config/redirect-manager.php</code>."|t('redirect-manager')|raw : null,
	            }) }}

				{% include 'lindemannrock-base/_components/info-box' with {
					message: '<strong>' ~ 'How it works'|t('redirect-manager') ~ ':</strong><br>'
					~ '• ' ~ 'Device detection parses user-agent strings to identify devices, browsers, and operating systems'|t('redirect-manager') ~ '<br>'
					~ '• ' ~ 'Results are cached to avoid re-parsing the same user-agent repeatedly'|t('redirect-manager') ~ '<br>'
					~ '• ' ~ 'Recommended to keep enabled for production sites'|t('redirect-manager')
				} %}
			</div>

			<hr>
		{% else %}

			<div class="field">
				<p class="light" style="color: #999;">
					{{ "Device detection caching is only available when Analytics is enabled. Go to"|t('redirect-manager') }}
					<a href="{{ url('redirect-manager/settings/analytics') }}">{{ "Analytics Settings"|t('redirect-manager') }}</a>
					{{ "to enable analytics."|t('redirect-manager') }}
				</p>
			</div>

			<hr>
		{% endif %}

		<h2>{{ "Redirect Caching"|t('redirect-manager') }}</h2>

		{{ forms.lightswitchField({
            label: 'Enable Redirect Cache'|t('redirect-manager'),
            instructions: 'Cache redirect lookups for improved performance. Recommended for production sites.'|t('redirect-manager'),
            id: 'enableRedirectCache',
            name: 'settings[enableRedirectCache]',
            on: settings.enableRedirectCache,
            toggle: 'redirect-cache-settings',
            errors: settings.getErrors('enableRedirectCache'),
            disabled: settings.isOverriddenByConfig('enableRedirectCache'),
            warning: settings.isOverriddenByConfig('enableRedirectCache') ?
                "This is being overridden by the <code>enableRedirectCache</code> setting in <code>config/redirect-manager.php</code>."|t('redirect-manager')|raw : null,
        }) }}

		<div id="redirect-cache-settings" class="{{ not settings.enableRedirectCache ? 'hidden' }}">
			{{ forms.textField({
	            label: 'Redirect Cache Duration'|t('redirect-manager'),
	            instructions: ('Cache duration in seconds. Current:'|t('redirect-manager') ~ ' <strong id="redirectCacheDuration-human"></strong>')|raw,
	            id: 'redirectCacheDuration',
	            name: 'settings[redirectCacheDuration]',
	            value: settings.redirectCacheDuration ?? 3600,
	            type: 'number',
	            min: 60,
	            max: 86400,
	            tip: 'Min: 60 (1 minute), Max: 86400 (1 day)'|t('redirect-manager'),
                errors: settings.getErrors('redirectCacheDuration'),
	            disabled: settings.isOverriddenByConfig('redirectCacheDuration'),
	            warning: settings.isOverriddenByConfig('redirectCacheDuration') ?
	                "This is being overridden by the <code>redirectCacheDuration</code> setting in <code>config/redirect-manager.php</code>."|t('redirect-manager')|raw : null,
	        }) }}
		</div>

		<div class="buttons">
			<button type="submit" class="btn submit">{{ "Save Settings"|t('redirect-manager') }}</button>
		</div>
	</form>

	{% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}

{% js %}
// Toggle cache location info boxes based on storage method selection
$('#cacheStorageMethod').on('change', function() {
	const value = $(this).val();
	if (value === 'redis') {
		$('#cache-location-file').addClass('hidden');
		$('#cache-location-redis').removeClass('hidden');
	} else {
		$('#cache-location-redis').addClass('hidden');
		$('#cache-location-file').removeClass('hidden');
	}
});

// Convert seconds to human-readable duration
var _timeUnits = {
	second: {{ '{count} second'|t('redirect-manager', {count: '__COUNT__'})|json_encode|raw }},
	seconds: {{ '{count} seconds'|t('redirect-manager', {count: '__COUNT__'})|json_encode|raw }},
	minute: {{ '{count} minute'|t('redirect-manager', {count: '__COUNT__'})|json_encode|raw }},
	minutes: {{ '{count} minutes'|t('redirect-manager', {count: '__COUNT__'})|json_encode|raw }},
	hour: {{ '{count} hour'|t('redirect-manager', {count: '__COUNT__'})|json_encode|raw }},
	hours: {{ '{count} hours'|t('redirect-manager', {count: '__COUNT__'})|json_encode|raw }},
	day: {{ '{count} day'|t('redirect-manager', {count: '__COUNT__'})|json_encode|raw }},
	days: {{ '{count} days'|t('redirect-manager', {count: '__COUNT__'})|json_encode|raw }}
};
function secondsToHuman(seconds) {
	seconds = parseInt(seconds) || 0;
	if (seconds < 60) {
		return _timeUnits[seconds !== 1 ? 'seconds' : 'second'].replace('__COUNT__', seconds);
	} else if (seconds < 3600) {
		var mins = Math.round(seconds / 60 * 10) / 10;
		return _timeUnits[mins !== 1 ? 'minutes' : 'minute'].replace('__COUNT__', mins);
	} else if (seconds < 86400) {
		var hours = Math.round(seconds / 3600 * 10) / 10;
		return _timeUnits[hours !== 1 ? 'hours' : 'hour'].replace('__COUNT__', hours);
	} else {
		var days = Math.round(seconds / 86400 * 10) / 10;
		return _timeUnits[days !== 1 ? 'days' : 'day'].replace('__COUNT__', days);
	}
}

// Update human-readable duration on input change
$('#deviceDetectionCacheDuration').on('input', function() {
	$('#deviceDetectionCacheDuration-human').text(secondsToHuman($(this).val()));
});

$('#redirectCacheDuration').on('input', function() {
	$('#redirectCacheDuration-human').text(secondsToHuman($(this).val()));
});

// Initialize on page load
$('#deviceDetectionCacheDuration-human').text(secondsToHuman($('#deviceDetectionCacheDuration').val()));
$('#redirectCacheDuration-human').text(secondsToHuman($('#redirectCacheDuration').val()));
{% endjs %}

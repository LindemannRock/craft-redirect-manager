<h2 class="first">{{ "Test URL Redirects"|t('redirect-manager') }}</h2>

<div class="pane" style="margin-bottom: 30px;">
    <p class="light">{{ "Test if a URL matches any of your configured redirects without actually visiting it. Useful for validating Source Match Mode (path vs full URL) and Match Type logic."|t('redirect-manager') }}</p>

    <div class="field">
        <div class="heading">
            <label for="testUrl">{{ "Test URL"|t('redirect-manager') }}</label>
            <div class="instructions">
                <p>{{ "Enter a URL to test (can be a full URL like https://example.com/old-page or a path like /old-page)"|t('redirect-manager') }}</p>
            </div>
        </div>
        <div class="input ltr">
            <input type="text" id="testUrl" class="text fullwidth" placeholder="/old-page or https://example.com/old-page">
        </div>
    </div>

    <button type="button" id="testButton" class="btn submit">{{ "Test URL"|t('redirect-manager') }}</button>
</div>

<div id="testResults" style="display: none; margin-top: 30px;">
    <div class="pane">
        <h3 id="resultsTitle" class="first"></h3>
        <div id="resultsContent"></div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const testButton = document.getElementById('testButton');
    const testUrlInput = document.getElementById('testUrl');
    const testResults = document.getElementById('testResults');
    const resultsTitle = document.getElementById('resultsTitle');
    const resultsContent = document.getElementById('resultsContent');
    const escapeHtml = function(value) {
        return Craft.escapeHtml(String(value ?? ''));
    };
    const redirectEditUrl = function(id) {
        return Craft.getUrl('redirect-manager/redirects/' + encodeURIComponent(String(parseInt(id, 10) || '')));
    };
    const T = {
        createRedirect: {{ 'Create Redirect for This URL'|t('redirect-manager')|json_encode|raw }},
        destination: {{ 'Destination'|t('redirect-manager')|json_encode|raw }},
        destinationUrl: {{ 'Destination URL'|t('redirect-manager')|json_encode|raw }},
        error: {{ 'Error'|t('redirect-manager')|json_encode|raw }},
        fullUrl: {{ 'Full URL'|t('redirect-manager')|json_encode|raw }},
        id: {{ 'ID'|t('redirect-manager')|json_encode|raw }},
        matchFound: {{ 'Match Found!'|t('redirect-manager')|json_encode|raw }},
        matchType: {{ 'Match Type'|t('redirect-manager')|json_encode|raw }},
        noMatchFound: {{ 'No Match Found'|t('redirect-manager')|json_encode|raw }},
        noRedirectConfigured: {{ 'No redirect configured for this URL.'|t('redirect-manager')|json_encode|raw }},
        otherRedirectsTemplate: {{ '{count} other redirect(s) also match this URL'|t('redirect-manager')|json_encode|raw }},
        pathOnly: {{ 'Path Only'|t('redirect-manager')|json_encode|raw }},
        priority: {{ 'Priority'|t('redirect-manager')|json_encode|raw }},
        redirectId: {{ 'Redirect ID'|t('redirect-manager')|json_encode|raw }},
        resolvesTo: {{ 'Resolves to:'|t('redirect-manager')|json_encode|raw }},
        skippedLowerPriority: {{ 'Skipped due to lower priority (higher number = lower priority)'|t('redirect-manager')|json_encode|raw }},
        source: {{ 'Source'|t('redirect-manager')|json_encode|raw }},
        sourceMatchMode: {{ 'Source Match Mode'|t('redirect-manager')|json_encode|raw }},
        sourceUrl: {{ 'Source URL'|t('redirect-manager')|json_encode|raw }},
        statusCode: {{ 'Status Code'|t('redirect-manager')|json_encode|raw }},
        testUrl: {{ 'Test URL'|t('redirect-manager')|json_encode|raw }},
        testing: {{ 'Testing...'|t('redirect-manager')|json_encode|raw }},
        thisUrlWouldRedirect: {{ 'This URL would redirect:'|t('redirect-manager')|json_encode|raw }},
        validationError: {{ 'Validation Error'|t('redirect-manager')|json_encode|raw }},
        visiting: {{ 'Visiting'|t('redirect-manager')|json_encode|raw }},
        wouldResult404: {{ 'would result in a 404 error and be logged in analytics.'|t('redirect-manager')|json_encode|raw }},
    };

    testButton.addEventListener('click', function() {
        let testUrl = testUrlInput.value.trim();

        if (!testUrl) {
            testResults.style.display = 'block';
            resultsTitle.textContent = '⚠️ ' + T.validationError;
            resultsTitle.style.color = '#dc3545';
            resultsContent.innerHTML = '<p style="color: #dc3545;">' + {{ 'Please enter a URL to test'|t('redirect-manager')|json_encode|raw }} + '</p>';
            return;
        }

        const isFullUrl = testUrl.startsWith('http://') || testUrl.startsWith('https://');
        const isPath = testUrl.startsWith('/');

        if (!isFullUrl && !isPath) {
            if (testUrl.includes('.')) {
                testUrl = 'https://' + testUrl;
                testUrlInput.value = testUrl;
            } else {
                testUrl = '/' + testUrl;
                testUrlInput.value = testUrl;
            }
        }

        testButton.disabled = true;
        testButton.textContent = T.testing;

        fetch('{{ actionUrl('redirect-manager/settings/test-url') }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json',
                'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
            },
            body: JSON.stringify({
                testUrl: testUrl
            })
        })
        .then(response => response.json())
        .then(data => {
            testButton.disabled = false;
            testButton.textContent = T.testUrl;

            testResults.style.display = 'block';

            if (data.matched) {
                resultsTitle.textContent = '✅ ' + T.matchFound;
                resultsTitle.style.color = '#28a745';

                const r = data.redirect;
                const resolvedDestinationUrl = escapeHtml(r.resolvedDestinationUrl);
                const destinationUrl = escapeHtml(r.destinationUrl);
                resultsContent.innerHTML = `
<p style="padding: 15px; background: #e8f5e9; border-left: 4px solid #28a745; margin: 15px 0;">
    <strong>${escapeHtml(T.thisUrlWouldRedirect)}</strong><br>
    <code>${escapeHtml(testUrl)}</code>
    →
    <code>${resolvedDestinationUrl}</code>
</p>
<dl style="display: grid; grid-template-columns: 200px 1fr; gap: 10px; margin: 20px 0;">
    <dt>
        <strong>${escapeHtml(T.redirectId)}:</strong>
    </dt>
    <dd>
        <a href="${redirectEditUrl(r.id)}">#${escapeHtml(r.id)}</a>
    </dd>

    <dt>
        <strong>${escapeHtml(T.sourceUrl)}:</strong>
    </dt>
    <dd>
        <code>${escapeHtml(r.sourceUrl)}</code>
    </dd>

    <dt>
        <strong>${escapeHtml(T.destinationUrl)}:</strong>
    </dt>
    <dd>
        <code>${destinationUrl}</code>
        ${r.destinationUrl !== r.resolvedDestinationUrl ? `<br><span style="color: #28a745;">→ ${escapeHtml(T.resolvesTo)} <code>${resolvedDestinationUrl}</code></span>` : ''}
    </dd>

    <dt>
        <strong>${escapeHtml(T.matchType)}:</strong>
    </dt>
    <dd>${escapeHtml(r.matchType)}</dd>

    <dt>
        <strong>${escapeHtml(T.sourceMatchMode)}:</strong>
    </dt>
    <dd>${r.redirectSrcMatch === 'pathonly' ? escapeHtml(T.pathOnly) : escapeHtml(T.fullUrl)}</dd>

    <dt>
        <strong>${escapeHtml(T.statusCode)}:</strong>
    </dt>
    <dd>${escapeHtml(r.statusCode)}</dd>

    <dt>
        <strong>${escapeHtml(T.priority)}:</strong>
    </dt>
    <dd>${escapeHtml(r.priority)}</dd>
</dl>
${data.alsoMatches && data.alsoMatches.length > 0 ? `
<div style="margin-top: 25px;">
    <p><strong>${escapeHtml(T.otherRedirectsTemplate.replace('{count}', data.alsoMatches.length))}</strong></p>
    <p class="light" style="margin: 0 0 12px 0;">${escapeHtml(T.skippedLowerPriority)}</p>
    <div class="tableview">
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th style="width: 80px;">${escapeHtml(T.id)}</th>
                    <th>${escapeHtml(T.source)}</th>
                    <th>${escapeHtml(T.destination)}</th>
                    <th style="width: 80px;">${escapeHtml(T.priority)}</th>
                </tr>
            </thead>
            <tbody>
                ${data.alsoMatches.map(m => `
                    <tr>
                        <td><a href="${redirectEditUrl(m.id)}">#${escapeHtml(m.id)}</a></td>
                        <td><code>${escapeHtml(m.sourceUrl)}</code></td>
                        <td><code>${escapeHtml(m.resolvedDestinationUrl)}</code></td>
                        <td>${escapeHtml(m.priority)}</td>
                    </tr>
                `).join('')}
            </tbody>
        </table>
    </div>
</div>
` : ''}
`;
            } else {
                resultsTitle.textContent = '❌ ' + T.noMatchFound;
                resultsTitle.style.color = '#dc3545';

                const createParams = {
                    sourceUrl: testUrl
                };

                if (testUrl.startsWith('http://') || testUrl.startsWith('https://')) {
                    createParams.redirectSrcMatch = 'fullurl';
                }

                resultsContent.innerHTML = `
<p style="padding: 15px; background: #fff3cd; border-left: 4px solid #ffc107; margin: 15px 0;">
    <strong>${escapeHtml(T.noRedirectConfigured)}</strong><br>
    ${escapeHtml(T.visiting)}
    <code>${escapeHtml(testUrl)}</code>
    ${escapeHtml(T.wouldResult404)}
</p>
<p style="margin-top: 15px;">
    <a href="${Craft.getUrl('redirect-manager/redirects/new', createParams)}" class="btn">${escapeHtml(T.createRedirect)}</a>
</p>
`;
            }
        })
        .catch(error => {
            testButton.disabled = false;
            testButton.textContent = T.testUrl;

            testResults.style.display = 'block';
            resultsTitle.textContent = '⚠️ ' + T.error;
            resultsTitle.style.color = '#dc3545';
            resultsContent.innerHTML = `<p style="color: #dc3545;">${escapeHtml(error.message)}</p>`;
        });
    });

    testUrlInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            testButton.click();
        }
    });
});
</script>

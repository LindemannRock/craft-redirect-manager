{% extends "_layouts/cp" %}
{% set title = "Preview Import"|t('redirect-manager') %}
{% set fullPageForm = false %}
{% set selectedSubnavItem = 'import-export' %}

{% set plugin = craft.app.plugins.getPlugin('redirect-manager') %}
{% set crumbs = [
    {
        label: redirectHelper.fullName|t('redirect-manager'),
        url: url('redirect-manager'),
    },
    {
        label: 'Import/Export'|t('redirect-manager'),
        url: url('redirect-manager/import-export'),
    },
    {
        label: 'Preview'|t('redirect-manager'),
    },
] %}

{% import "_includes/forms" as forms %}

{% block content %}
    <h2 class="first">{{ "Import Preview"|t('redirect-manager') }}</h2>

    <div class="lr-unified-cards cols-4 lr-mt-30 lr-mb-30">
        {% include 'lindemannrock-base/_components/unified-card' with {
            value: summary.totalRows,
            description: 'Total Rows'|t('redirect-manager'),
            align: 'center',
        } only %}
        {% include 'lindemannrock-base/_components/unified-card' with {
            value: summary.validRows,
            description: 'Valid'|t('redirect-manager'),
            palette: 'green',
            align: 'center',
        } only %}
        {% include 'lindemannrock-base/_components/unified-card' with {
            value: summary.duplicates,
            description: 'Duplicates'|t('redirect-manager'),
            palette: 'amber',
            align: 'center',
        } only %}
        {% include 'lindemannrock-base/_components/unified-card' with {
            value: summary.errors,
            description: 'Errors'|t('redirect-manager'),
            palette: 'red',
            align: 'center',
        } only %}
    </div>

    {% if createBackup %}
        {% if existingCount > 0 %}
            {% include 'lindemannrock-base/_components/info-box' with {
                message: '<strong>' ~ "Backup will be created with {count} existing redirect(s) before importing to protect your data."|t('redirect-manager', {count: existingCount}) ~ '</strong>',
                type: 'success',
                variant: 'colored',
                margin: 'bottom'
            } %}
        {% else %}
            {% include 'lindemannrock-base/_components/info-box' with {
                message: '<strong>' ~ "No existing redirects to backup - backup will be skipped."|t('redirect-manager') ~ '</strong>',
                type: 'info',
                variant: 'colored',
                margin: 'bottom'
            } %}
        {% endif %}
    {% endif %}

    {% if validRows|length > 0 %}
        <hr>
        <h3>{{ "Valid Redirects to Import"|t('redirect-manager') }} ({{ validRows|length }})</h3>
        <div class="lr-preview-table lr-preview-table--tall">
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>{{ "Source URL"|t('redirect-manager') }}</th>
                        <th>{{ "Destination URL"|t('redirect-manager') }}</th>
                        <th>{{ "Site"|t('redirect-manager') }}</th>
                        <th>{{ "Match Type"|t('redirect-manager') }}</th>
                        <th>{{ "Source Match"|t('redirect-manager') }}</th>
                        <th>{{ "Status"|t('redirect-manager') }}</th>
                        <th>{{ "Priority"|t('redirect-manager') }}</th>
                        <th>{{ "Enabled"|t('redirect-manager') }}</th>
                        <th>{{ "Hits"|t('redirect-manager') }}</th>
                        <th>{{ "Last Hit"|t('redirect-manager') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in validRows %}
                        <tr>
                            <td><code>{{ row.sourceUrl }}</code></td>
                            <td><code>{{ row.destinationUrl }}</code></td>
                            <td class="lr-nowrap">
                                {% if row.siteId %}
                                    {% set site = craft.app.sites.getSiteById(row.siteId) %}
                                    {{ site ? site.name : row.siteId }}
                                {% else %}
                                    <span class="light">{{ 'All Sites'|t('redirect-manager') }}</span>
                                {% endif %}
                            </td>
                            <td>{{ row.matchType }}</td>
                            <td>{{ row.redirectSrcMatch }}</td>
                            <td>{{ row.statusCode }}</td>
                            <td>{{ row.priority }}</td>
                            <td>{{ row.enabled ? 'Yes'|t('redirect-manager') : 'No'|t('redirect-manager') }}</td>
                            <td>{{ row.hitCount ?? 0 }}</td>
                            <td class="lr-nowrap lr-text-sm">{{ row.lastHit ? row.lastHit : '-' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if duplicateRows|length > 0 %}
        <hr>
        <h3>{{ "Duplicate Redirects (will be skipped)"|t('redirect-manager') }} ({{ duplicateRows|length }})</h3>
        <p class="light">{{ "These redirects already exist with the same source URL, match type, and source match mode."|t('redirect-manager') }}</p>
        <div class="lr-preview-table">
            <table class="data fullwidth">
                <thead class="is-warning">
                    <tr>
                        <th>{{ "Source URL"|t('redirect-manager') }}</th>
                        <th>{{ "Destination URL"|t('redirect-manager') }}</th>
                        <th>{{ "Reason"|t('redirect-manager') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in duplicateRows %}
                        <tr>
                            <td><code>{{ row.sourceUrl }}</code></td>
                            <td><code>{{ row.destinationUrl }}</code></td>
                            <td class="light">{{ row.reason }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if errorRows|length > 0 %}
        <hr>
        <h3>{{ "Invalid Rows (will be skipped)"|t('redirect-manager') }} ({{ errorRows|length }})</h3>
        <div class="lr-preview-table">
            <table class="data fullwidth">
                <thead class="is-error">
                    <tr>
                        <th style="width: 60px;">{{ "Row"|t('redirect-manager') }}</th>
                        <th>{{ "Source URL"|t('redirect-manager') }}</th>
                        <th>{{ "Destination URL"|t('redirect-manager') }}</th>
                        <th>{{ "Error"|t('redirect-manager') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in errorRows %}
                        <tr>
                            <td>{{ row.rowNumber }}</td>
                            <td><code>{{ row.sourceUrl }}</code></td>
                            <td><code>{{ row.destinationUrl }}</code></td>
                            <td class="lr-text-danger">{{ row.error }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <hr>

    <form method="post" action="{{ actionUrl('redirect-manager/import-export/import') }}" id="importForm">
        {{ csrfInput() }}

        <div class="lr-import-summary">
            <h3 class="first">{{ "Ready to Import"|t('redirect-manager') }}</h3>
            <p>
                {% if summary.validRows > 0 %}
                    {{ "Click the button below to import {count} valid redirect(s)."|t('redirect-manager', {count: summary.validRows}) }}
                    {% if summary.duplicates > 0 %}
                        {{ "{duplicates} duplicate(s) will be skipped."|t('redirect-manager', {duplicates: summary.duplicates}) }}
                    {% endif %}
                    {% if summary.errors > 0 %}
                        {{ "{errors} invalid row(s) will be skipped."|t('redirect-manager', {errors: summary.errors}) }}
                    {% endif %}
                {% else %}
                    {{ "No valid redirects found to import."|t('redirect-manager') }}
                {% endif %}
            </p>

            <div class="buttons">
                <a href="{{ url('redirect-manager/import-export') }}" class="btn secondary">{{ "Cancel"|t('redirect-manager') }}</a>
                {% if summary.validRows > 0 %}
                    <button type="submit" class="btn submit">
                        {{ "Import {count} Redirects"|t('redirect-manager', {count: summary.validRows}) }}
                    </button>
                {% else %}
                    <button type="button" class="btn disabled" disabled>
                        {{ "No Valid Redirects to Import"|t('redirect-manager') }}
                    </button>
                {% endif %}
            </div>
        </div>
    </form>

    {% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}

{% js %}
    // Confirm before importing
    const importForm = document.getElementById('importForm');
    if (importForm) {
        importForm.addEventListener('submit', function(e) {
            const count = {{ summary.validRows }};
            let message = {{ 'Import {count} redirect(s)?'|t('redirect-manager')|json_encode|raw }}.replace('{count}', count);
            {% if createBackup %}
                message += ' ' + {{ 'A backup will be created first.'|t('redirect-manager')|json_encode|raw }};
            {% endif %}

            if (!confirm(message)) {
                e.preventDefault();
                return false;
            }
        });
    }
{% endjs %}
